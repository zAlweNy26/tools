{
  "$schema": "https://typedoc.org/schema.json",
  "includeVersion": true,
  "hideGenerator": true,
  "name": "Alwe's Tools",
  "cleanOutputDir": true,
  "plugin": [
    "typedoc-plugin-coverage",
    "typedoc-material-theme"
  ],
  "themeColor": "#cb9820",
  "entryPoints": [
    "./index.ts"
  ],
  "out": "./docs",
  "navigation": {
    "includeGroups": true
  },
  "navigationLinks": {
    "GitHub": "https://github.com/zAlweNy26/tools",
    "NPM": "https://www.npmjs.com/package/@danyalwe/tools"
  }
}
