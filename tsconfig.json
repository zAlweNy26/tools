{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@structures/*": ["./src/structures/*"],
      "@distances/*": ["./src/distances/*"],
      "@utils/*": ["./src/utils/*"],
      "@sortings/*": ["./src/sortings/*"],
      "@dim_red/*": ["./src/dim_red/*"],
      "@researches/*": ["./src/researches/*"]
    },
    "resolveJsonModule": true,
    "types": ["bun"],
    "allowJs": true,
    "strict": true,
    "strictFunctionTypes": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "eslint.config.mjs",
    "tsdown.config.ts",
    "./src/**/*.ts",
    "./test/**/*.ts",
    "index.ts"
  ]
}
