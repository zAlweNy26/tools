{
  "name": "@danyalwe/tools",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "bun@1.3.14",
  "description": "Package with a bunch of useful data structures and algorithms",
  "author": {
    "name": "zAlweNy26",
    "email": "alwe.dev@gmail.com",
    "url": "https://www.github.com/zAlweNy26"
  },
  "license": "MIT",
  "homepage": "https://github.com/zAlweNy26/tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/zAlweNy26/tools.git"
  },
  "bugs": {
    "url": "https://github.com/zAlweNy26/tools/issues"
  },
  "keywords": [
    "algorithms",
    "data structures",
    "structures",
    "dimensionality reduction",
    "module",
    "distances",
    "sortings",
    "helpers",
    "utils",
    "tools"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "bun run generate && tsdown",
    "release": "bun run build && changeset publish",
    "generate": "ctix create -p ./tsconfig.json -t -w --noBackup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "docs": "typedoc index.ts",
    "test": "bun test",
    "start": "tsx watch index.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "ctix": "^2.8.1",
    "eslint": "^10.6.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-material-theme": "^1.4.1",
    "typedoc-plugin-coverage": "^4.0.3",
    "typescript": "^6.0.3"
  }
}
