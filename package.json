{
  "name": "@danyalwe/tools",
  "type": "module",
  "version": "0.1.4",
  "packageManager": "bun@1.3.14",
  "description": "A collection of data structures, algorithms, and utilities for TypeScript",
  "author": {
    "name": "zAlweNy26",
    "email": "alwe.dev@gmail.com",
    "url": "https://www.github.com/zAlweNy26"
  },
  "license": "MIT",
  "homepage": "https://github.com/zAlweNy26/tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zAlweNy26/tools.git"
  },
  "bugs": {
    "url": "https://github.com/zAlweNy26/tools/issues"
  },
  "keywords": [
    "algorithms",
    "data structures",
    "structures",
    "dimensionality reduction",
    "module",
    "distances",
    "sortings",
    "helpers",
    "utils",
    "tools"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsdown",
    "release": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "test": "bun test",
    "generate": "typedoc && bun run docs/.vitepress/coverage-badge.ts",
    "start": "tsx watch index.ts",
    "docs:dev": "bun run generate && vitepress dev docs",
    "docs:build": "bun run generate && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/bun": "^1.3.14",
    "changelogen": "^0.6.2",
    "eslint": "^10.6.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-coverage": "^4.0.3",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-plugin-merge-modules": "^7.0.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4"
  },
  "changelog": {
    "types": {
      "feat": {
        "title": "🚀 Enhancements",
        "semver": "patch"
      },
      "refactor": {
        "title": "💅 Refactors",
        "semver": "minor"
      }
    }
  }
}
